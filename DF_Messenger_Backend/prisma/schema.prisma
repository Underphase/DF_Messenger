generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int     @id @default(autoincrement())
  email       String  @unique
  password    String  @db.VarChar(255)
  nickName    String
  username    String?  @unique
  description String?
  avatarUrl   String? @db.VarChar(512)
  bannerUrl   String? @db.VarChar(512)
  isVerified  Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt()

  sentRequests     Friendship[]      @relation("sender")
  receivedRequests Friendship[]      @relation("receiver")
  blockedUsers     Block[]           @relation("blocker")
  blockedByUsers   Block[]           @relation("blocked")
  refreshToken     RefreshToken[]
  chatParticipants ChatParticipant[]
  messages         Message[]
  reactions        MessageReaction[]
  readReceipts     MessageRead[]
  deletedMessages  MessageDeletedFor[]
  pinnedMessages   ChatPinnedMessage[]
  deviceTokens     DeviceToken[]
}

model Friendship {
  id         Int              @id @default(autoincrement())
  senderId   Int
  receiverId Int
  status     FriendshipStatus @default(PENDING)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt()

  sender   User @relation("sender", fields: [senderId], references: [id])
  receiver User @relation("receiver", fields: [receiverId], references: [id])

  @@unique([senderId, receiverId])
}

model Block {
  id        Int      @id @default(autoincrement())
  blockerId Int
  blockedId Int
  createdAt DateTime @default(now())

  blocker User @relation("blocker", fields: [blockerId], references: [id])
  blocked User @relation("blocked", fields: [blockedId], references: [id])

  @@unique([blockerId, blockedId])
  @@index([blockedId])
  @@index([blockerId])
}

model Chat {
  id                  Int      @id @default(autoincrement())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt()

  participants    ChatParticipant[]
  messages        Message[]
  pinnedMessages  ChatPinnedMessage[]
}

model ChatParticipant {
  id         Int       @id @default(autoincrement())
  chatId     Int
  userId     Int
  lastReadAt DateTime?
  isHidden   Boolean   @default(false)

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@unique([chatId, userId])
}

model Message {
  id              Int         @id @default(autoincrement())
  chatId          Int
  senderId        Int
  content         String?
  type            MessageType @default(TEXT)
  mediaUrl        String?     @db.VarChar(512)
  forwardedFromId Int?
  musicTitle      String?     @db.VarChar(255)
  musicArtist     String?     @db.VarChar(255)
  musicCover      String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt()

  chat          Chat              @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender        User              @relation(fields: [senderId], references: [id])
  reactions     MessageReaction[]
  readReceipts  MessageRead[]
  forwardedFrom Message?          @relation("Forward", fields: [forwardedFromId], references: [id])
  forwardedTo   Message[]         @relation("Forward")
  deletedFor    MessageDeletedFor[]
  pinnedIn      ChatPinnedMessage[]

  @@index([chatId])
}

model MessageReaction {
  id        Int    @id @default(autoincrement())
  messageId Int
  userId    Int
  emoji     String

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
}

model MessageRead {
  id        Int      @id @default(autoincrement())
  messageId Int
  userId    Int
  readAt    DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
}

model MessageDeletedFor {
  id        Int      @id @default(autoincrement())
  messageId Int
  userId    Int
  deletedAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
}

model ChatPinnedMessage {
  id        Int      @id @default(autoincrement())
  chatId    Int
  messageId Int
  userId    Int?
  createdAt DateTime @default(now())

  chat    Chat    @relation(fields: [chatId], references: [id], onDelete: Cascade)
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, messageId])
  @@index([userId])
}

model RefreshToken {
  id                Int       @id @default(autoincrement())
  userId            Int
  familyId          String    @default(uuid()) @db.Uuid
  tokenHash         String    @db.Text
  previousTokenHash String?   @db.Text
  usedAt            DateTime?
  expiresAt         DateTime
  revoked           Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@index([userId, revoked])
}

model DeviceToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  platform  String   @default("android")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AppKeys {
  key      String  @unique
  adminKey Boolean @default(false)
}

model Devices {
  id        Int    @id @default(autoincrement())
  deviceKey String
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  VIDEO_NOTE
  FILE
  AUDIO
  VOICE
  MUSIC
}