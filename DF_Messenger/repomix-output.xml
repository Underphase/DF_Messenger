  Friends: 'users',
  Profile: 'user',
};

const TAB_LABELS: Record<string, string> = {
  Chats: 'Чаты',
  Friends: 'Друзья',
  Profile: 'Профиль',
};

// ─── Single tab item ──────────────────────────────────────────────────────────

interface TabItemProps {
